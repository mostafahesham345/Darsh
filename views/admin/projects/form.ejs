<% const isEdit = typeof mode !== 'undefined' && mode === 'edit'; const p = typeof project !== 'undefined' ? project : {}; %>
<%- include('../_head', { pageTitle: isEdit ? 'Edit project' : 'New project' }) %>

<div class="app-shell">
  <%- include('../_sidebar', { active: 'projects', adminEmail }) %>

  <main class="main">
    <div class="page-head">
      <h1><%= isEdit ? 'Edit project' : 'New project' %></h1>
      <p><a href="/admin/projects" style="color:var(--muted);">← Back to projects</a><% if (!isEdit) { %> · The client gets a welcome email when the project is created.<% } else { %> · Editing here doesn't email the client. Use the stage tracker to send updates.<% } %></p>
    </div>

    <form method="post" action="<%= isEdit ? '/admin/projects/' + p.id + '/edit' : '/admin/projects/new' %>" class="form">
      <div class="field">
        <label for="name">Project name *</label>
        <input id="name" name="name" type="text" value="<%= isEdit ? (p.name || '') : '' %>" required />
      </div>

      <div class="field">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3" placeholder="A short summary the client will see in emails."><%= isEdit ? (p.description || '') : '' %></textarea>
      </div>

      <h2 style="margin-top:18px;">Client</h2>
      <% if (clients.length) { %>
        <div class="field">
          <label for="clientId">Link to a client</label>
          <select id="clientId" name="clientId" <%= isEdit ? '' : 'required' %>>
            <option value="">— Select a client —</option>
            <% clients.forEach(function(c) { %>
              <option value="<%= c.id %>"
                <%= isEdit && p.clientId === c.id ? 'selected' : '' %>
                data-name="<%= c.name || '' %>" data-email="<%= c.email || '' %>"><%= c.name %><%= c.company ? ' — ' + c.company : '' %></option>
            <% }); %>
          </select>
        </div>
      <% } else if (!isEdit) { %>
        <div class="alert alert-warn">You need at least one client before creating a project. <a href="/admin/clients/new">Add a client</a> first.</div>
      <% } %>

      <h2 style="margin-top:18px;">Schedule</h2>
      <div class="row-2">
        <div class="field">
          <label for="startDate">Start date</label>
          <input id="startDate" name="startDate" type="date" value="<%= isEdit ? (p.startDate || '') : '' %>" />
        </div>
        <div class="field">
          <label for="targetDate">Target delivery date</label>
          <input id="targetDate" name="targetDate" type="date" value="<%= isEdit ? (p.targetDate || '') : '' %>" />
        </div>
      </div>

      <div class="row-2">
        <% if (!isEdit) { %>
          <div class="field">
            <label for="stage">Starting stage</label>
            <select id="stage" name="stage">
              <% stages.forEach(function(s) { %>
                <option value="<%= s.key %>" <%= s.key === 'discovery' ? 'selected' : '' %>><%= s.label %></option>
              <% }); %>
            </select>
          </div>
        <% } else { %>
          <div class="field">
            <label>Current stage</label>
            <input type="text" value="<%= (stages.find(function(s){return s.key===p.stage;}) || {label: p.stage || '—'}).label %>" disabled />
            <div class="help">To change the stage (and notify the client), use the project view page.</div>
          </div>
        <% } %>
        <div class="field">
          <label for="budget">Budget (optional)</label>
          <input id="budget" name="budget" type="text" value="<%= isEdit ? (p.budget || '') : '' %>" placeholder="e.g. USD 12,000" />
        </div>
      </div>

      <h2 style="margin-top:18px;">Build &amp; ownership</h2>
      <p class="hint">Who owns what, and the tool/provider behind each part of the site. Optional — you can fill or change this anytime, even after the project is done.</p>

      <div class="field">
        <label for="ownership">Overall ownership</label>
        <select id="ownership" name="ownership">
          <% const own = isEdit ? (p.ownership || '') : ''; %>
          <option value="" <%= own === '' ? 'selected' : '' %>>— Not set —</option>
          <option value="Client-Owned" <%= own === 'Client-Owned' ? 'selected' : '' %>>Client-Owned (client holds the accounts)</option>
          <option value="Managed" <%= own === 'Managed' ? 'selected' : '' %>>Managed (we host &amp; maintain)</option>
        </select>
      </div>

      <label style="display:block;font-weight:600;margin:6px 0 8px;">Sections &amp; tools</label>
      <p class="help" style="margin-top:-4px;">For each part of the site, note the tool/provider and who owns it.</p>
      <div id="sections"></div>
      <button type="button" class="repeater-add" id="addSection">+ Add section</button>

      <div class="form-actions">
        <a href="/admin/projects" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-yellow" <%= (clients.length || isEdit) ? '' : 'disabled' %>><%= isEdit ? 'Save changes' : 'Create & notify client' %></button>
      </div>
    </form>
  </main>
</div>

<script>
  const OWNER_OPTS = ['', 'Client', 'Provider (us)', 'Shared'];
  const sectionsWrap = document.getElementById('sections');

  function addSection(name = '', tool = '', owner = '') {
    const row = document.createElement('div');
    row.className = 'repeater-item';
    const ownerOptions = OWNER_OPTS.map((o) =>
      `<option value="${o.replace(/"/g, '&quot;')}" ${o === owner ? 'selected' : ''}>${o || '— Owner —'}</option>`).join('');
    const safe = (s) => String(s).replace(/"/g, '&quot;');
    row.innerHTML = `
      <button type="button" class="remove-btn">Remove</button>
      <div class="row-2">
        <div class="field"><label>Section</label><input type="text" name="sectionName" value="${safe(name)}" placeholder="e.g. Hosting, Domain, Payments" /></div>
        <div class="field"><label>Tool / provider</label><input type="text" name="sectionTool" value="${safe(tool)}" placeholder="e.g. Render, GoDaddy, Stripe" /></div>
      </div>
      <div class="field"><label>Owner</label><select name="sectionOwner">${ownerOptions}</select></div>`;
    row.querySelector('.remove-btn').addEventListener('click', () => row.remove());
    sectionsWrap.appendChild(row);
  }

  document.getElementById('addSection').addEventListener('click', () => addSection());

  <% if (isEdit && Array.isArray(p.sections) && p.sections.length) { %>
    <% p.sections.forEach(function(s) { %>
      addSection(<%- JSON.stringify(s.name || '') %>, <%- JSON.stringify(s.tool || '') %>, <%- JSON.stringify(s.owner || '') %>);
    <% }); %>
  <% } else if (!isEdit) { %>
    // Starter rows for a fresh project (just guidance — edit or remove freely).
    ['Domain', 'Hosting / Server', 'Email', 'Payments', 'Content / CMS', 'Media / Storage', 'Analytics']
      .forEach((s) => addSection(s, '', ''));
  <% } %>

  const projPicker = document.getElementById('clientId');
  if (projPicker) {
    projPicker.addEventListener('change', (e) => {
      const opt = e.target.options[e.target.selectedIndex];
      // (client name/email are resolved server-side from clientId on submit)
    });
  }
</script>
</body>
</html>
