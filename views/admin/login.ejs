<%- include('./_head', { pageTitle: 'Sign in' }) %>

<div class="login-shell">
  <div class="login-card">
    <div class="brand">
      <img src="/images/LogoDark.png" alt="" class="login-logo" />
      <div>
        <div class="name">Darsh Admin</div>
        <small style="color: var(--muted);">Website content manager</small>
      </div>
    </div>
    <h1>Sign in</h1>
    <p>Enter your email and password to manage the website.</p>

    <% if (error) { %>
      <div class="alert alert-err"><%= error %></div>
    <% } %>

    <form method="post" action="/admin/login">
      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required autofocus />
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required />
      </div>
      <button type="submit" class="btn btn-yellow" style="width:100%;">Sign in</button>
    </form>
  </div>
</div>
</body>
</html>
