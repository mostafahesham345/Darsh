<%- include('../_head', { pageTitle: 'Tech ticker' }) %>

<div class="app-shell">
  <%- include('../_sidebar', { active: 'content:ticker', adminEmail }) %>

  <main class="main">
    <div class="page-head">
      <h1>⚡ Tech ticker</h1>
      <p>The scrolling list of technologies that runs under the hero.</p>
    </div>

    <% if (saved) { %><div class="alert alert-ok">Saved! Your changes are live.</div><% } %>
    <% if (!firebaseReady) { %><div class="alert alert-warn">Firebase isn't connected — saves won't work.</div><% } %>

    <form method="post" action="/admin/content/ticker" class="form-root">
      <div class="form">
        <h2>Items</h2>
        <p class="hint">Type an item and press Enter to add it. Click the × on a chip to remove it.</p>
        <div class="chip-input" data-chipinput data-name="items">
          <% (section.items || []).forEach(function(item) { %>
            <span class="chip">
              <input type="hidden" name="items[]" value="<%= item %>" />
              <span><%= item %></span>
              <button type="button" aria-label="Remove">×</button>
            </span>
          <% }); %>
          <input type="text" placeholder="Type and press Enter…" />
        </div>
      </div>

      <%- include('../_form_footer') %>
    </form>
  </main>
</div>
</body>
</html>
