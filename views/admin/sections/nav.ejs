<%- include('../_head', { pageTitle: 'Top navigation' }) %>

<div class="app-shell">
  <%- include('../_sidebar', { active: 'content:nav', adminEmail }) %>

  <main class="main">
    <div class="page-head">
      <h1>🧭 Top navigation</h1>
      <p>The bar at the top of every page — logo, menu items, and the portal button.</p>
    </div>

    <% if (saved) { %><div class="alert alert-ok">Saved! Your changes are live.</div><% } %>
    <% if (!firebaseReady) { %><div class="alert alert-warn">Firebase isn't connected — saves won't work.</div><% } %>

    <form method="post" action="/admin/content/nav" class="form-root">
      <div class="form">
        <h2>Logo</h2>
        <p class="hint">Shown in the top-left corner of the page.</p>
        <div class="image-uploader" data-uploader data-key="logo">
          <div class="image-drop">
            <div class="preview<%= !section.images.logo.url ? ' empty' : '' %>" style="<%= section.images.logo.url ? `background-image: url('${section.images.logo.url}')` : '' %>">
              <% if (!section.images.logo.url) { %>No image<% } %>
            </div>
            <div class="actions">
              <label class="pick">Choose image<input type="file" accept="image/*" /></label>
              <button type="button" class="clear">Remove</button>
              <small>PNG with transparency. Max 8MB.</small>
            </div>
          </div>
          <input type="hidden" name="images[logo][url]" value="<%= section.images.logo.url || '' %>" />
          <input type="hidden" name="images[logo][path]" value="<%= section.images.logo.path || '' %>" />
        </div>
      </div>

      <div class="form">
        <h2>Portal button</h2>
        <div class="field">
          <label>Button text</label>
          <input type="text" name="fields[portalLabel]" value="<%= section.fields.portalLabel %>" />
          <div class="help">The text on the yellow button at the end of the nav.</div>
        </div>
      </div>

      <div class="form">
        <h2>Menu items</h2>
        <p class="hint">The links in the middle of the nav bar. You can reorder, add, or remove them.</p>
        <div class="repeater" data-repeater data-template="navLink">
          <% (section.links || []).forEach(function(link, i) { %>
            <div class="repeater-item">
              <h4>Menu item #<span class="idx"><%= i + 1 %></span></h4>
              <button type="button" class="remove-btn">Remove</button>
              <div class="row-2">
                <div class="field">
                  <label>Text shown on screen</label>
                  <input type="text" name="links[<%= i %>][label]" value="<%= link.label %>" />
                </div>
                <div class="field">
                  <label>Link / anchor</label>
                  <input type="text" name="links[<%= i %>][href]" value="<%= link.href %>" />
                  <div class="help">Use <code>#section</code> for same-page links.</div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
        <button type="button" class="repeater-add">+ Add menu item</button>

        <template data-tpl="navLink">
          <div class="repeater-item">
            <h4>Menu item #<span class="idx">__I__</span></h4>
            <button type="button" class="remove-btn">Remove</button>
            <div class="row-2">
              <div class="field"><label>Text shown on screen</label><input type="text" name="links[__I0__][label]" /></div>
              <div class="field"><label>Link / anchor</label><input type="text" name="links[__I0__][href]" /></div>
            </div>
          </div>
        </template>
      </div>

      <%- include('../_form_footer') %>
    </form>
  </main>
</div>
</body>
</html>
